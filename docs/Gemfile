source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "just-the-docs"
gem "jekyll-seo-tag"
gem "jekyll-relative-links"
gem "jekyll-include-cache"
gem "webrick"

# Windows and JRuby lack a system tz database; bundle it so Jekyll's
# set_timezone can load tzinfo. wdm speeds up file watching on Windows.
platforms :windows, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
  gem "wdm", ">= 0.1.0"
end