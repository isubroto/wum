<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="WUM"
           Manufacturer="Subroto Saha"
           Version="$(var.ProductVersion)"
           UpgradeCode="3f2a9c14-7b6e-4d28-9a51-0c8e6b1f2d77">

    <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" />

    <!-- Upgrade handling -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of WUM is already installed." />
    <util:CloseApplication Id="CloseRunningWum"
                           Target="wum.exe"
                           Description="WUM is running and will close so the update can continue."
                           CloseMessage="yes"
                           ElevatedCloseMessage="yes"
                           EndSessionMessage="yes"
                           ElevatedEndSessionMessage="yes"
                           Timeout="2"
                           TerminateProcess="1"
                           RebootPrompt="no" />

    <!-- Directories -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="subroto" Name="Subroto Saha">
        <Directory Id="INSTALLFOLDER" Name="WUM" />
      </Directory>
    </StandardDirectory>

    <!-- CLI tool: add install dir to machine PATH so `wum` runs in any terminal -->
    <Component Id="PathEnv" Directory="INSTALLFOLDER" Guid="*">
      <Environment Id="UpdatePath"
                   Name="PATH"
                   Value="[INSTALLFOLDER]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <RegistryValue Root="HKLM" Key="Software\WUM" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Icon Id="wum.ico" SourceFile="..\src\WUM.CLI\wum.ico" />
    <Property Id="ARPPRODUCTICON" Value="wum.ico" />

    <!-- Feature -->
    <Feature Id="ProductFeature" Title="WUM" Level="1">
      <!-- AppFiles includes wum.exe and all dependency files -->
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="PathEnv" />
    </Feature>

  </Package>
</Wix>
